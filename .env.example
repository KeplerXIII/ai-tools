# Скопируй в .env и подставь свои значения.
# Схема имён переменных совпадает с полями в app/core/config.py (UPPER_SNAKE).

# --- приложение ---
# APP_NAME=AI Tools Service
# APP_VERSION=0.1.0
# DEBUG=false
# REQUEST_TIMEOUT=45
# MAX_HTML_LENGTH=10000000

# =============================================================================
# LLM: OpenAI-совместимый API (DeepSeek, Ollama, vLLM, др.)
# =============================================================================
#
# Глобальный дефолт: все задачи (саммари, перевод, теги, сущности, …) ходят
# сюда, если для задачи не задано своё переопределение ниже.
#
# OPENAI_COMPAT_BASE_URL — базовый URL провайдера (без лишнего слэша в конце).
#   Примеры:
#     DeepSeek:     https://api.deepseek.com
#     Ollama:       http://127.0.0.1:11434/v1
#     LM Studio:    http://localhost:1234/v1
#
# OPENAI_COMPAT_API_KEY — ключ провайдера (у Ollama часто достаточно "ollama").
#
OPENAI_COMPAT_BASE_URL=https://api.deepseek.com
OPENAI_COMPAT_API_KEY=sk-your-api-key-here

# -----------------------------------------------------------------------------
# Переопределение URL и ключа только для одной задачи
# -----------------------------------------------------------------------------
#
# Суффикс в имени переменной = задача в коде (LLMTask):
#   summary              — summarize_text (первичная аннотация)
#   summary_refine       — refine_summary (уточнение аннотации)
#   translation          — перевод
#   tagging              — теги
#   entity_extraction    — извлечение сущностей
#
# Если переменная не задана или пустая — используются OPENAI_COMPAT_BASE_URL
# и OPENAI_COMPAT_API_KEY.
#
# Пример: перевод на локальную Ollama, остальное на DeepSeek:
#   OPENAI_COMPAT_BASE_URL=https://api.deepseek.com
#   OPENAI_COMPAT_API_KEY=sk-deepseek-...
#   OPENAI_COMPAT_BASE_URL_TRANSLATION=http://127.0.0.1:11434/v1
#   OPENAI_COMPAT_API_KEY_TRANSLATION=ollama
#
# OPENAI_COMPAT_BASE_URL_SUMMARY=
# OPENAI_COMPAT_API_KEY_SUMMARY=
# OPENAI_COMPAT_BASE_URL_SUMMARY_REFINE=
# OPENAI_COMPAT_API_KEY_SUMMARY_REFINE=
# OPENAI_COMPAT_BASE_URL_TRANSLATION=
# OPENAI_COMPAT_API_KEY_TRANSLATION=
# OPENAI_COMPAT_BASE_URL_TAGGING=
# OPENAI_COMPAT_API_KEY_TAGGING=
# OPENAI_COMPAT_BASE_URL_ENTITY_EXTRACTION=
# OPENAI_COMPAT_API_KEY_ENTITY_EXTRACTION=

# =============================================================================
# Модели по задачам
# =============================================================================
#
# Имя модели должно существовать у того провайдера, на который указывает
# endpoint для этой задачи (глобальный или переопределённый URL выше).
#
# Если переменная не задана — берётся дефолт из config.py (сейчас deepseek-v4-pro).
#
# MODEL_SUMMARY=
# MODEL_SUMMARY_REFINE=
# MODEL_TRANSLATION=
# MODEL_TAGGING=
# MODEL_ENTITY_EXTRACTION=

# LLM_TIMEOUT=120

# =============================================================================
# Embeddings (TEI: embedding-tei в compose; без GPU — docker-compose.dev.yml, cpu-1.6)
# =============================================================================
#
# EMBEDDING_ENABLED=true
# EMBEDDING_TEI_BASE_URL=http://embedding-tei/v1
# EMBEDDING_TEI_API_KEY=tei
# EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_CATALOG_MODEL_NAME=bge-m3
# Read-only том TEI в compose: EMBEDDING_TOKENIZER_HUB_ROOT=/tei-hub/hub
# EMBEDDING_TOKENIZER_LOCAL_PATH=/tei-hub/hub/models--BAAI--bge-m3/snapshots/<rev>
# EMBEDDING_TOKENIZER_HUB_ROOT=
# EMBEDDING_TOKENIZER_CACHE_DIR=
# EMBEDDING_TOKENIZER_LOCAL_FILES_ONLY=false
# EMBEDDING_CHUNK_TOKENS_ORIGINAL=512
# EMBEDDING_CHUNK_OVERLAP_TOKENS_ORIGINAL=128
# EMBEDDING_CHUNK_TOKENS_TRANSLATED=512
# EMBEDDING_CHUNK_OVERLAP_TOKENS_TRANSLATED=128
# EMBEDDING_CHUNK_TOKENS_ANNOTATION=512
# EMBEDDING_CHUNK_OVERLAP_TOKENS_ANNOTATION=64
# EMBEDDING_TIMEOUT_SEC=120
# EMBEDDING_FAIL_OPEN=true
#
# С хоста (без Docker): http://127.0.0.1:8089/v1

# =============================================================================
# RAG (POST /api/v1/rag/ask; HNSW cosine — миграция 20260519_01)
# =============================================================================
#
# RAG_ENABLED=true
# RAG_RETRIEVAL_STRATEGY=vector
# hybrid = вектор + PostgreSQL FTS; hybrid_bm25 = вектор + Okapi BM25
# RAG_RERANKER=cross_encoder
# RAG_FETCH_K=40
# RAG_TOP_K=12
# RAG_MAX_CHUNKS_PER_DOCUMENT=3
# RAG_MAX_CONTEXT_TOKENS=6000
# Порог score после rerank (0–1). Пример с cross_encoder: 0.15
# RAG_MIN_SIMILARITY=0.15
# RAG_DEFAULT_CHUNK_TYPES=translated,original,annotation
# RAG_HNSW_EF_SEARCH=64
# RAG_FTS_CONFIG=russian
# RAG_BM25_K1=1.5
# RAG_BM25_B=0.75
# RAG_BM25_INDEX_ON_EMBED=true
# RAG_RRF_K=60
# Docker (сервис rerank-tei в compose): без /v1, с хоста http://127.0.0.1:8090
# RAG_RERANK_BASE_URL=http://rerank-tei:80
# RAG_RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
# RAG_RERANK_TIMEOUT_SEC=60
# RAG_RERANK_BI_ENCODER_FALLBACK=true
# RAG_RERANK_MAX_BATCH_SIZE=32
# RAG_EMBEDDING_REQUEST_BATCH_SIZE=8
# RAG_QUERY_EXPANSION=false
# RAG_QUERY_EXPANSION_COUNT=2
# MODEL_RAG=deepseek-v4-pro
# OPENAI_COMPAT_BASE_URL_RAG=
# OPENAI_COMPAT_API_KEY_RAG=

# =============================================================================
# PostgreSQL + JWT (авторизация /api/v1/auth/*)
# =============================================================================
#
# DATABASE_URL — async-драйвер для SQLAlchemy:
#   postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# В Docker по имени контейнера (сеть ai_stack): hostname `ai-tools-postgres`.
# Пароль должен совпадать с POSTGRES_PASSWORD в docker-compose.yml.
#
# DATABASE_URL=postgresql+asyncpg://aitools:your-password@ai-tools-postgres:5432/aitools
#
# SAQ queue (Redis) для фоновых задач:
# SAQ_QUEUE_URL=redis://ai-tools-redis:6379/0
# SAQ_TRANSLATE_QUEUE_NAME=ai-tools-translate
# SAQ_TRANSLATE_WORKER_CONCURRENCY=1
# SAQ_ANNOTATE_QUEUE_NAME=ai-tools-annotate
# SAQ_ANNOTATE_WORKER_CONCURRENCY=1
# SAQ_CATEGORIZE_QUEUE_NAME=ai-tools-categorize
# SAQ_CATEGORIZE_WORKER_CONCURRENCY=5
# SAQ_EXTRACTOR_QUEUE_NAME=ai-tools-extractor
# SAQ_EXTRACTOR_WORKER_CONCURRENCY=5
# SAQ_TAGGER_QUEUE_NAME=ai-tools-tagger
# SAQ_TAGGER_WORKER_CONCURRENCY=5
# SAQ_TRANSLATE_JOB_TIMEOUT_SEC=1800
# SAQ_ANNOTATE_JOB_TIMEOUT_SEC=1800
# SAQ_CATEGORIZE_JOB_TIMEOUT_SEC=1800
# SAQ_EXTRACTOR_JOB_TIMEOUT_SEC=1800
# SAQ_TAGGER_JOB_TIMEOUT_SEC=1800
#
# JWT_SECRET_KEY — длинная случайная строка (например: openssl rand -hex 32).
# Не коммить реальный ключ в репозиторий.
#
# JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
#
# Сессия SQLAdmin (/admin); если не задан — используется JWT_SECRET_KEY.
# ADMIN_SESSION_SECRET=
#
# Схема БД — только Alembic (init_db вызывает то же самое):
#   docker compose exec ai-tools uv run alembic upgrade head
#   docker compose exec ai-tools uv run python -m app.cli.init_db
#
# Первый админ SQLAdmin: зарегистрируйте пользователя через /api/v1/auth/register,
# затем:
#   docker compose exec ai-tools uv run python -m app.cli.promote_admin USERNAME
#
# С хоста (порт 5432 на localhost), не меняя DATABASE_URL для Docker:
#   DATABASE_URL_FOR_CLI=postgresql+asyncpg://USER:PASS@127.0.0.1:5432/aitools \
#     uv run python -m app.cli.init_db